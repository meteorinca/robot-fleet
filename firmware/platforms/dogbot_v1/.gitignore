# Gitignore for ESP-IDF projects

# Build directory (contains all generated files, object files, binaries, etc.)
build/

# Components managed by ESP-IDF Component Manager
managed_components/

# IDE specific folders
.vscode/
.idea/
.vs/
*.swp
*.swo

# sdkconfig backups (we usually want to keep the main sdkconfig, but not the .old backup)
sdkconfig.old
dependencies.lock

# Python compiled files
__pycache__/
*.py[cod]
*$py.class

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Secrets
secrets.h
main/secrets.h

# Jupyter
.ipynb_checkpoints